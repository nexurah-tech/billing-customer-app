# ─────────────────────────────────────────────────────────────
# NexBill Frontend - Environment Variables Template
# Copy this file to .env.local for local development.
# ─────────────────────────────────────────────────────────────

# URL of the running standalone Express backend server (required)
NEXT_PUBLIC_API_URL=http://127.0.0.1:5000

# Optional Electron configuration (set to true ONLY when packing desktop app)
# ELECTRON_BUILD=true
